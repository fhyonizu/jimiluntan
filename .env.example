# ==========================================
# 基米论坛 环境变量配置
# 复制此文件为 .env 并填写真实值
# ==========================================

# Flask 密钥（生产环境必须修改！可用以下命令生成随机密钥：）
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string
JWT_SECRET_KEY=change-me-to-another-random-string

# JWT Token 有效期（天数）
JWT_DAYS=7

# CORS 允许的前端地址（Docker+Nginx 同域部署时留空即可）
CORS_ORIGINS=

# Flask 调试模式（开发 = 1，生产 = 0）
FLASK_DEBUG=1

# ----------------
# GIF 搜索（可选，至少配置一个）
# ----------------

# Giphy API Key — https://developers.giphy.com/
GIPHY_API_KEY=
VITE_GIPHY_API_KEY=your_giphy_api_key_here

# Tenor API Key — https://tenor.com/developer （免费，每天10,000次）
TENOR_API_KEY=
